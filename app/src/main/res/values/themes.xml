<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Whoopie — base application theme -->
    <style name="Theme.Client" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Brand primary -->
        <item name="colorPrimary">@color/whoopie_primary</item>
        <item name="colorPrimaryVariant">@color/whoopie_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Brand secondary -->
        <item name="colorSecondary">@color/whoopie_cyan</item>
        <item name="colorSecondaryVariant">@color/whoopie_primary_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Window & status bar -->
        <item name="android:statusBarColor">@color/whoopie_bg</item>
        <item name="android:navigationBarColor">@color/whoopie_bg</item>
        <item name="android:windowBackground">@color/whoopie_bg</item>
    </style>
</resources>
